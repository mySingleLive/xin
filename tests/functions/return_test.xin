// Test complex return value scenarios

func add(a: int64, b: int64) int64 {
    return a + b
}

func mul(a: int64, b: int64) int64 {
    return a * b
}

func square(x: int64) int64 {
    return x * x
}

func compute() int64 {
    return add(10, 20) + mul(3, 4)
}

func chain1() int64 {
    return 5
}

func chain2(x: int64) int64 {
    return x + 10
}

func chain3(x: int64) int64 {
    return x * 2
}

func nested_add(a: int64, b: int64) int64 {
    return add(a, b)
}

func max(a: int64, b: int64) int64 {
    if (a > b) {
        return a
    }
    return b
}

func is_greater(a: int64, b: int64) bool {
    return a > b
}

func main() {
    println(add(10, 20) + 5)
    println(mul(3, 4) - 2)
    println(add(add(1, 2), add(3, 4)))
    println(square(add(2, 3)))
    println(compute())
    println(chain3(chain2(chain1())))
    println(nested_add(100, 200))
    println(max(10, 20))
    println(max(30, 15))
    if (is_greater(10, 5)) {
        println(1)
    }
    if (!is_greater(10, 5)) {
        println(0)
    }
    println(add(mul(2, 3), square(4)))
}