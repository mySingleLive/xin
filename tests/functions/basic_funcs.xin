// Test basic functions

func sayHello() {
    println("hello")
}

func greet(name: string) {
    println("greeting: " + name)
}

func add(a: int64, b: int64) int64 {
    return a + b
}

func sum(a: int64, b: int64, c: int64) int64 {
    return a + b + c
}

func nested() int64 {
    return add(20, 22)
}

func main() {
    sayHello()
    greet("Alice")
    println(add(10, 5))
    println(sum(10, 10, 10))
    println(nested())
}